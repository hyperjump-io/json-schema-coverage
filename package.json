{
  "name": "@hyperjump/json-schema-coverage",
  "version": "1.2.1",
  "description": "Test coverage tools for JSON Schema testing",
  "keywords": [
    "JSON Schema",
    "test",
    "coverage",
    "vitest",
    "matcher",
    "toMatchJsonSchema",
    "matchJsonSchema"
  ],
  "author": "Jason Desrosiers <jdesrosi@gmail.com>",
  "license": "MIT",
  "repository": "github:hyperjump-io/json-schema-coverage",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/jdesrosiers"
  },
  "type": "module",
  "exports": {
    ".": "./src/index.js",
    "./vitest": "./src/vitest/index.js"
  },
  "scripts": {
    "lint": "eslint src",
    "test": "vitest run --config src/vitest/vitest-json-schema.config.js --coverage",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "docs": "typedoc"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "*",
    "@types/content-type": "*",
    "@types/istanbul-lib-coverage": "*",
    "@types/istanbul-reports": "*",
    "@types/moo": "*0",
    "@types/node": "*",
    "@types/picomatch": "*",
    "@types/unist": "*",
    "eslint-import-resolver-typescript": "*",
    "eslint-plugin-import": "*",
    "typedoc": "*",
    "typescript-eslint": "*",
    "vitest": "*"
  },
  "dependencies": {
    "@hyperjump/browser": "^1.3.1",
    "@hyperjump/json-schema": "^1.17.2",
    "@hyperjump/uri": "^1.3.1",
    "content-type": "^2.0.0",
    "ignore": "^7.0.5",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.1.7",
    "moo": "^0.5.2",
    "pathe": "^2.0.3",
    "picomatch": "^4.0.2",
    "tinyglobby": "^0.2.14",
    "vfile": "^6.0.3",
    "yaml": "^2.8.0",
    "yaml-unist-parser": "^3.1.0"
  }
}
